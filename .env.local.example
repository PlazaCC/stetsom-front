# Fastify API base URL (server-side only — no NEXT_PUBLIC_ needed)
# Local dev: http://localhost:3333
# Production or Staging (Vercel env var): https://api.yourdomain.com
# CMS_API_BASE_URL=http://localhost:3333

# Mock data toggle — set to 1 to serve from src/lib/mock/data.json (no API needed)
# Local dev: USE_MOCK_DATA=1
# Vercel dev + PR preview: also set to 1, via Vercel dashboard → Settings → Environment Variables
# USE_MOCK_DATA=1

# Credentials used only by `pnpm mock:dump` to export admin endpoints
# MOCK_DUMP_EMAIL=admin@stetsom.com.br
# MOCK_DUMP_PASSWORD=your-password

# JWT secrets — must match stetsom-api/.env
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me

# S3/R2 public hostname for next/image — derived from backend S3_BUCKET + S3_REGION
STORAGE_PUBLIC_HOSTNAME=your-bucket.s3.us-east-1.amazonaws.com
