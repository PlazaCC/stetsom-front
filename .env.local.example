# Fastify API base URL
# Set to use the remote provider. Without it, mock data is used automatically.
# CMS_API_BASE_URL=http://localhost:3333

# Force BFF mode — use remote provider even without CMS_API_BASE_URL.
# Will break without one (intentional — for testing).
# CMS_FORCE_BFF=1

# JWT secrets — must match stetsom-api/.env
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me

# S3/R2 storage public hostname — so next/image can optimize bucket assets
# Example for S3: stetsom-dev.s3.sa-east-1.amazonaws.com
# Example for R2: pub-abc123.r2.dev
STORAGE_PUBLIC_HOSTNAME=stetsom-dev.s3.sa-east-1.amazonaws.com
