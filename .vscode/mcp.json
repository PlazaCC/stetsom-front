{
  "servers": {
    "Framelink_Figma_MCP": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "figma-developer-mcp", "--figma-api-key=your_figma_api", "--stdio"]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "plaza.mcp": {
      "type": "http",
      "url": "https://plaza-mcp.plaza.workers.dev/mcp"
    },
  }
}
